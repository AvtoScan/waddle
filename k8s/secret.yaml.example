# Copy this file to secret.yaml, fill in values, apply, then DELETE the file.
# Never commit secret.yaml to git.
#
# Alternatively, create the secret via CLI:
#
#   kubectl create secret generic waddle-secrets \
#     --from-literal=TELEGRAM_BOT_TOKEN=your_token \
#     --from-literal=TELEGRAM_CHAT_ID=your_chat_id \
#     --from-literal=DISCORD_WEBHOOK_URL=your_webhook \
#     --from-literal=SMTP_HOST=smtp.example.com \
#     --from-literal=SMTP_USER=you@example.com \
#     --from-literal=SMTP_PASS=yourpassword \
#     --from-literal=WEBHOOK_URL=https://your-webhook.example.com
#
apiVersion: v1
kind: Secret
metadata:
  name: waddle-secrets
  labels:
    app: waddle
type: Opaque
stringData:
  TELEGRAM_BOT_TOKEN:  ""
  TELEGRAM_CHAT_ID:    ""
  DISCORD_WEBHOOK_URL: ""
  SMTP_HOST:           ""
  SMTP_USER:           ""
  SMTP_PASS:           ""
  WEBHOOK_URL:         ""
